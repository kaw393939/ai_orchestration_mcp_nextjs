{
  "name": "is601_demo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prestart": "npm run validate:env",
    "dev": "next dev",
    "prebuild": "npm run build:search-index",
    "build": "next build",
    "build:search-index": "tsx scripts/build-search-index.ts",
    "build:search-index:force": "tsx scripts/build-search-index.ts --force",
    "release:prepare": "npm run build && node scripts/generate-release-manifest.mjs",
    "release:verify": "node scripts/validate-release-manifest.mjs",
    "run": "npm run release:verify && npm run start",
    "start": "node scripts/start-server.mjs",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:env": "tsx scripts/validate-env.ts",
    "admin:validate-env": "tsx scripts/admin-validate-env.ts",
    "admin:health": "tsx scripts/admin-health-sweep.ts",
    "admin:diagnostics": "tsx scripts/admin-diagnostics.ts",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "check:stateless": "node scripts/assert-stateless-runtime.mjs",
    "parity:env": "node scripts/validate-env-parity.mjs",
    "mcp:calculator": "tsx mcp/calculator-server.ts",
    "typecheck": "tsc --noEmit",
    "lint:strict": "eslint --max-warnings 0",
    "quality": "npm run typecheck && npm run lint:strict && npm run test",
    "lhci": "lhci autorun",
    "lhci:dev": "lhci collect --url=http://localhost:3000 && lhci assert"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "mermaid": "^11.12.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
